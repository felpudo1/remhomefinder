# =============================================================================
# RemHomeFinder — Variables de entorno
# =============================================================================
# Copiar este archivo a .env y completar los valores.
# Nunca commitear .env al repositorio (ya está en .gitignore).
#
# Uso:
#   cp .env.example .env
#   (editar .env con tus claves)
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Vite) — Cliente Supabase
# -----------------------------------------------------------------------------
# El cliente en src/integrations/supabase/client.ts lee siempre estas variables.
# Lovable / CI deben definirlas en el panel de entorno del proyecto.
#
# Obtenerlas en: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL="https://TU_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
VITE_SUPABASE_PROJECT_ID="TU_PROJECT_REF"

# -----------------------------------------------------------------------------
# Edge Functions (Supabase) — Solo si vas a correr o desplegar funciones
# -----------------------------------------------------------------------------
# Se configuran en Supabase Dashboard → Project Settings → Edge Functions
# o con: supabase secrets set NOMBRE=valor

# URL del proyecto (igual que VITE_SUPABASE_URL pero sin prefijo VITE_)
# SUPABASE_URL="https://TU_PROJECT_REF.supabase.co"

# Clave de servicio (service_role). ¡Nunca exponer en el frontend!
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Clave anónima (anon key) para crear cliente en algunas funciones
# SUPABASE_ANON_KEY="eyJ..."

# APIs externas usadas por scrape-property y extract-from-image
# FIRECRAWL_API_KEY="fc-..."
# ZENROWS_API_KEY="..."
# LOVABLE_API_KEY="..."   # Si usás IA de Lovable en las funciones
# =============================================================================
