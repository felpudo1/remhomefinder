# =====================================================
# PaymentMP - Variables de Entorno del Backend
# =====================================================
# 
# Copiá este archivo como .env y completá tus credenciales:
#   cp .env.example .env
#
# Obtené las credenciales en:
#   https://www.mercadopago.com/developers/panel/credentials
# =====================================================

# --- MercadoPago ---
# Access Token (PRIVADO - solo para el backend)
MERCADOPAGO_ACCESS_TOKEN=TEST-tu-access-token-aqui

# --- Servidor ---
# Puerto del backend API
PORT=3001

# --- URLs ---
# URL del frontend (para CORS y back_urls de MercadoPago)
FRONTEND_URL=http://localhost:3000

# URL del backend (para webhook notifications)
BACKEND_URL=http://localhost:3001
